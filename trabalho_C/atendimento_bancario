// Liberação de memória
void liberarFila(Fila *f) {
    No *atual = f->inicio;

    while (atual != NULL) {
        No *remover = atual;
        atual = atual->prox;
        free(remover);
    }

    f->inicio = NULL;
    f->fim = NULL;
    f->quantidade = 0;
}

void liberarFilaCircular(Fila *f) {
    if (filaVazia(f)) {
        return;
    }

    No *atual = f->inicio;
    No *primeiro = f->inicio;

    do {
        No *remover = atual;
        atual = atual->prox;
        free(remover);
    } while (atual != primeiro);

    f->inicio = NULL;
    f->fim = NULL;
    f->quantidade = 0;
}

