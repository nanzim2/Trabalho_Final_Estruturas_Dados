}

// CSV
void salvarFilaNormalCSV(Fila *normal) {
    FILE *arquivo = fopen(ARQ_NORMAL, "w");

    if (arquivo == NULL) {
        mensagemErro("Erro ao salvar fila normal.");
        return;
    }

    fprintf(arquivo, "senha;tipo;horario\n");

    No *atual = normal->inicio;

    while (atual != NULL) {
        fprintf(arquivo, "%d;%c;%s\n",
                atual->dado.senha,
                atual->dado.tipo,
                atual->dado.horario);

        atual = atual->prox;
    }

    fclose(arquivo);
}

void salvarFilaPreferencialCSV(Fila *pref) {
    FILE *arquivo = fopen(ARQ_PREF, "w");

    if (arquivo == NULL) {
        mensagemErro("Erro ao salvar fila preferencial.");
        return;
    }

    fprintf(arquivo, "senha;tipo;horario\n");

    if (!filaVazia(pref)) {
        No *atual = pref->inicio;

        do {
            fprintf(arquivo, "%d;%c;%s\n",
                    atual->dado.senha,
                    atual->dado.tipo,
                    atual->dado.horario);

            atual = atual->prox;

        } while (atual != pref->inicio);
    }

    fclose(arquivo);
}

void salvarTudoCSV(Fila *normal, Fila *pref) {
    salvarFilaNormalCSV(normal);
    salvarFilaPreferencialCSV(pref);

    mensagemSucesso("Dados salvos em CSV.");
}

void carregarFilaNormalCSV(Fila *normal, Sistema *s) {
    FILE *arquivo = fopen(ARQ_NORMAL, "r");
    char linha[100];

    if (arquivo == NULL) {
        mensagemAviso("Arquivo normal nao encontrado.");
        return;
    }

    liberarFila(normal);
    inicializarFila(normal);

    fgets(linha, sizeof(linha), arquivo);

    while (fgets(linha, sizeof(linha), arquivo) != NULL) {
        Registro r;
        char *campo;

        campo = strtok(linha, ";");

        if (campo == NULL) {
            continue;
        }

        r.senha = atoi(campo);

        campo = strtok(NULL, ";");

        if (campo == NULL) {
            continue;
        }

        r.tipo = campo[0];

        campo = strtok(NULL, ";\n");

        if (campo == NULL) {
            continue;
        }

        strcpy(r.horario, campo);

        enfileirar(normal, r);

        if (r.senha >= s->proximaSenha) {
            s->proximaSenha = r.senha + 1;
        }
    }

    fclose(arquivo);
}

void carregarFilaPreferencialCSV(Fila *pref, Sistema *s) {
    FILE *arquivo = fopen(ARQ_PREF, "r");
    char linha[100];

    if (arquivo == NULL) {
        mensagemAviso("Arquivo preferencial nao encontrado.");
        return;
    }

    liberarFilaCircular(pref);
    inicializarFila(pref);

    fgets(linha, sizeof(linha), arquivo);

    while (fgets(linha, sizeof(linha), arquivo) != NULL) {
        Registro r;
        char *campo;

        campo = strtok(linha, ";");

        if (campo == NULL) {
            continue;
        }

        r.senha = atoi(campo);

        campo = strtok(NULL, ";");

        if (campo == NULL) {
            continue;
        }

        r.tipo = campo[0];

        campo = strtok(NULL, ";\n");

        if (campo == NULL) {
            continue;
        }

        strcpy(r.horario, campo);

        enfileirarCircular(pref, r);

        if (r.senha >= s->proximaSenha) {
            s->proximaSenha = r.senha + 1;
        }
    }

    fclose(arquivo);
}

void carregarTudoCSV(Fila *normal, Fila *pref, Sistema *s) {
    carregarFilaNormalCSV(normal, s);
    carregarFilaPreferencialCSV(pref, s);

    mensagemSucesso("Carregamento finalizado.");
}

