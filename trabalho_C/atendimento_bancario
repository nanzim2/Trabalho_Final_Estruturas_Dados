// Inicialização
void inicializarFila(Fila *f) {
    f->inicio = NULL;
    f->fim = NULL;
    f->quantidade = 0;
}

void inicializarSistema(Sistema *s) {
    s->totalAtendidos = 0;
    s->atendidosNormais = 0;
    s->atendidosPreferenciais = 0;
    s->limiteNormais = 2;
    s->contadorNormais = 0;
    s->proximaSenha = 1;
}

// Fila normal encadeada
int filaVazia(Fila *f) {
    return f->inicio == NULL;
}

void enfileirar(Fila *f, Registro r) {
    No *novo = (No *) malloc(sizeof(No));

    if (novo == NULL) {
        mensagemErro("Falha ao alocar memoria.");
        return;
    }

    novo->dado = r;
    novo->prox = NULL;

    if (filaVazia(f)) {
        f->inicio = novo;
        f->fim = novo;
    } else {
        f->fim->prox = novo;
        f->fim = novo;
    }

    f->quantidade++;
}

int desenfileirar(Fila *f, Registro *r) {
    if (filaVazia(f)) {
        return 0;
    }

    No *remover = f->inicio;
    *r = remover->dado;

    f->inicio = f->inicio->prox;

    if (f->inicio == NULL) {
        f->fim = NULL;
    }

    free(remover);
    f->quantidade--;

    return 1;
}

int consultarProximo(Fila *f, Registro *r) {
    if (filaVazia(f)) {
        return 0;
    }

    *r = f->inicio->dado;
    return 1;
}

void listarFila(Fila *f, char nomeFila[]) {
    titulo(nomeFila);

    if (filaVazia(f)) {
        mensagemAviso("Fila vazia.");
        return;
    }

    No *atual = f->inicio;

    while (atual != NULL) {
        mostrarRegistro(atual->dado);
        atual = atual->prox;
    }
}

// Fila circular encadeada
void enfileirarCircular(Fila *f, Registro r) {
    No *novo = (No *) malloc(sizeof(No));

    if (novo == NULL) {
        mensagemErro("Falha ao alocar memoria.");
        return;
    }

    novo->dado = r;

    if (filaVazia(f)) {
        f->inicio = novo;
        f->fim = novo;
        novo->prox = novo;
    } else {
        novo->prox = f->inicio;
        f->fim->prox = novo;
        f->fim = novo;
    }

    f->quantidade++;
}

int desenfileirarCircular(Fila *f, Registro *r) {
    if (filaVazia(f)) {
        return 0;
    }

    No *remover = f->inicio;
    *r = remover->dado;

    if (f->inicio == f->fim) {
        f->inicio = NULL;
        f->fim = NULL;
    } else {
        f->inicio = f->inicio->prox;
        f->fim->prox = f->inicio;
    }

    free(remover);
    f->quantidade--;

    return 1;
}

int consultarProximoCircular(Fila *f, Registro *r) {
    if (filaVazia(f)) {
        return 0;
    }

    *r = f->inicio->dado;
    return 1;
}

void listarFilaCircular(Fila *f, char nomeFila[]) {
    titulo(nomeFila);

    if (filaVazia(f)) {
        mensagemAviso("Fila vazia.");
        return;
    }

    No *atual = f->inicio;

    do {
        mostrarRegistro(atual->dado);
        atual = atual->prox;
    } while (atual != f->inicio);
}

// Busca
No *buscarNoFilaNormal(Fila *f, int senha) {
    No *atual = f->inicio;

    while (atual != NULL) {
        if (atual->dado.senha == senha) {
            return atual;
        }

        atual = atual->prox;
    }

    return NULL;
}

No *buscarNoFilaCircular(Fila *f, int senha) {
    if (filaVazia(f)) {
        return NULL;
    }

    No *atual = f->inicio;

    do {
        if (atual->dado.senha == senha) {
            return atual;
        }

        atual = atual->prox;

    } while (atual != f->inicio);

    return NULL;
}

void buscarSenha(Fila *normal, Fila *pref) {
    int senha;

    titulo("BUSCAR SENHA");

    printf("Digite a senha: ");
    scanf("%d", &senha);
    limparBuffer();

    No *n = buscarNoFilaNormal(normal, senha);
    No *p = buscarNoFilaCircular(pref, senha);

    if (n != NULL) {
        mensagemSucesso("Senha encontrada na fila normal.");
        mostrarRegistro(n->dado);
    }
    else if (p != NULL) {
        mensagemSucesso("Senha encontrada na fila preferencial.");
        mostrarRegistro(p->dado);
    }
    else {
        mensagemAviso("Senha nao encontrada.");
    }
}

// Cancelamento de senhas
int cancelarNaFilaNormal(Fila *f, int senha) {
    No *atual = f->inicio;
    No *anterior = NULL;

    while (atual != NULL) {
        if (atual->dado.senha == senha) {

            if (anterior == NULL) {
                f->inicio = atual->prox;
            } else {
                anterior->prox = atual->prox;
            }

            if (atual == f->fim) {
                f->fim = anterior;
            }

            free(atual);
            f->quantidade--;

            if (f->quantidade == 0) {
                f->inicio = NULL;
                f->fim = NULL;
            }

            return 1;
        }

        anterior = atual;
        atual = atual->prox;
    }

    return 0;
}

int cancelarNaFilaCircular(Fila *f, int senha) {
    if (filaVazia(f)) {
        return 0;
    }

    No *atual = f->inicio;
    No *anterior = f->fim;

    do {
        if (atual->dado.senha == senha) {

            if (atual == f->inicio && atual == f->fim) {
                f->inicio = NULL;
                f->fim = NULL;
            } else {
                anterior->prox = atual->prox;

                if (atual == f->inicio) {
                    f->inicio = atual->prox;
                }

                if (atual == f->fim) {
                    f->fim = anterior;
                }

                f->fim->prox = f->inicio;
            }

            free(atual);
            f->quantidade--;
            return 1;
        }

        anterior = atual;
        atual = atual->prox;

    } while (atual != f->inicio);

    return 0;
}

void cancelarSenha(Fila *normal, Fila *pref) {
    int senha;
    char confirma;

    titulo("CANCELAR SENHA");

    printf("Digite a senha: ");
    scanf("%d", &senha);
    limparBuffer();

    No *n = buscarNoFilaNormal(normal, senha);
    No *p = buscarNoFilaCircular(pref, senha);

    if (n == NULL && p == NULL) {
        mensagemAviso("Senha nao encontrada.");
        return;
    }

    printf("\nSenha localizada:\n");

    if (n != NULL) {
        mostrarRegistro(n->dado);
    } else {
        mostrarRegistro(p->dado);
    }

    printf("\nConfirma cancelamento? (S/N): ");
    scanf(" %c", &confirma);
    limparBuffer();

    confirma = toupper(confirma);

    if (confirma != 'S') {
        mensagemAviso("Cancelamento abortado.");
        return;
    }

    if (n != NULL) {
        cancelarNaFilaNormal(normal, senha);
    } else {
        cancelarNaFilaCircular(pref, senha);
    }

    mensagemSucesso("Senha cancelada.");
}

// Geração e atendimento de senhas
Registro criarRegistro(Sistema *s, char tipo) {
    Registro r;

    r.senha = s->proximaSenha++;
    r.tipo = tipo;

    printf("Digite o horario de chegada (ex: 09:05): ");
    fgets(r.horario, 20, stdin);
    r.horario[strcspn(r.horario, "\n")] = '\0';

    if (strlen(r.horario) == 0) {
        strcpy(r.horario, "00:00");
    }

    return r;
}

void gerarSenha(Fila *normal, Fila *pref, Sistema *s) {
    char tipo;

    titulo("GERAR SENHA");

    do {
        printf("N - Normal\n");
        printf("P - Preferencial\n");
        printf("Opcao: ");
        scanf(" %c", &tipo);
        limparBuffer();

        tipo = toupper(tipo);

        if (tipo != 'N' && tipo != 'P') {
            mensagemErro("Digite apenas N ou P.");
        }

    } while (tipo != 'N' && tipo != 'P');

    Registro r = criarRegistro(s, tipo);

    if (tipo == 'N') {
        enfileirar(normal, r);
        mensagemSucesso("Senha adicionada na fila normal.");
    } else {
        enfileirarCircular(pref, r);
        mensagemSucesso("Senha adicionada na fila preferencial.");
    }

    mostrarRegistro(r);
}

void salvarRelatorioAtendimento(Registro r) {
    FILE *arquivo = fopen(ARQ_RELATORIO, "a");

    if (arquivo == NULL) {
        mensagemErro("Erro ao abrir relatorio.");
        return;
    }

    fprintf(arquivo, "%d;%c;%s\n", r.senha, r.tipo, r.horario);
    fclose(arquivo);
}

void chamarProximo(Fila *normal, Fila *pref, Sistema *s) {
    Registro atendido;
    int chamou = 0;

    titulo("CHAMAR PROXIMO");

    if (filaVazia(normal) && filaVazia(pref)) {
        mensagemAviso("Nao ha senhas aguardando.");
        return;
    }

    if (!filaVazia(normal) &&
        (filaVazia(pref) || s->contadorNormais < s->limiteNormais)) {

        chamou = desenfileirar(normal, &atendido);
        s->contadorNormais++;

    } else {
        chamou = desenfileirarCircular(pref, &atendido);
        s->contadorNormais = 0;
    }

    if (chamou) {
        printf("\n%s>>> SENHA CHAMADA <<<%s\n", VERDE, RESET);
        mostrarRegistro(atendido);

        s->totalAtendidos++;

        if (atendido.tipo == 'N') {
            s->atendidosNormais++;
        } else {
            s->atendidosPreferenciais++;
        }

        salvarRelatorioAtendimento(atendido);
    }
}

void consultarProximos(Fila *normal, Fila *pref) {
    Registro r;

    titulo("CONSULTAR PROXIMOS");

    printf("\nProximo NORMAL:\n");

    if (consultarProximo(normal, &r)) {
        mostrarRegistro(r);
    } else {
        mensagemAviso("Fila normal vazia.");
    }

    printf("\nProximo PREFERENCIAL:\n");

    if (consultarProximoCircular(pref, &r)) {
        mostrarRegistro(r);
    } else {
        mensagemAviso("Fila preferencial vazia.");
    }
}

void listarTodas(Fila *normal, Fila *pref) {
    listarFila(normal, "FILA NORMAL");
    listarFilaCircular(pref, "FILA PREFERENCIAL");
}

// Configuração de prioridade
void configurarPrioridade(Sistema *s) {
    int novo;

    titulo("CONFIGURAR PRIORIDADE");

    printf("Regra atual: %d normal(is) para 1 preferencial.\n",
           s->limiteNormais);

    printf("Nova quantidade de normais antes da preferencial: ");

    if (scanf("%d", &novo) != 1) {
        limparBuffer();
        mensagemErro("Entrada invalida.");
        return;
    }

    limparBuffer();

    if (novo <= 0) {
        mensagemErro("Valor invalido.");
        return;
    }

    s->limiteNormais = novo;
    s->contadorNormais = 0;

    mensagemSucesso("Prioridade atualizada.");
}

// Estatísticas
void mostrarEstatisticas(Fila *normal, Fila *pref, Sistema *s) {
    titulo("ESTATISTICAS");

    printf("Total atendido: %d\n", s->totalAtendidos);
    printf("Normais atendidos: %d\n", s->atendidosNormais);
