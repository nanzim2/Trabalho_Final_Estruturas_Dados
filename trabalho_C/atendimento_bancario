// Registro da senha
typedef struct {
    int senha;
    char tipo;
    char horario[20];
} Registro;

// Nó da lista encadeada
typedef struct No {
    Registro dado;
    struct No *prox;
} No;

// Estrutura da fila
typedef struct {
    No *inicio;
    No *fim;
    int quantidade;
} Fila;

// Controle geral do sistema
typedef struct {
    int totalAtendidos;
    int atendidosNormais;
    int atendidosPreferenciais;
    int limiteNormais;
    int contadorNormais;
    int proximaSenha;
} Sistema;

